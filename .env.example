# ─────────────────────────────────────────────────────────────────────────────
# AutoJobApplier — Environment Variables
# Copy to .env and fill in real values. Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
DB_HOST=db
DB_PORT=5432
DB_NAME=autojobapplier
DB_USER=postgres
DB_PASSWORD=changeme_strong_password_here

# Full async URL (auto-constructed in docker-compose; override here for external DB)
# DATABASE_URL=postgresql+asyncpg://postgres:changeme@localhost:5432/autojobapplier

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme_redis_password_here
# REDIS_URL=redis://:changeme_redis_password_here@localhost:6379/0

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=changeme_jwt_secret_key_at_least_64_chars_long_here

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DATABASE_ENCRYPTION_KEY=changeme_fernet_key_here

# Access token lifetime in minutes (default 15)
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Refresh token lifetime in days (default 7)
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── LLM / Anthropic ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-changeme
# Default model — swap here to change globally
LLM_MODEL=claude-sonnet-4-6
# Maximum tokens for generation (resume tailoring needs more)
LLM_MAX_TOKENS=4096

# ── Gmail OAuth (optional — can use IMAP instead) ─────────────────────────────
GMAIL_CLIENT_ID=changeme.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=changeme
GMAIL_REDIRECT_URI=http://localhost:3000/api/auth/gmail/callback

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_BACKEND=local
# For S3-compatible:
# STORAGE_BACKEND=s3
# S3_BUCKET=autojobapplier-files
# S3_ENDPOINT_URL=https://s3.amazonaws.com
# AWS_ACCESS_KEY_ID=changeme
# AWS_SECRET_ACCESS_KEY=changeme
# AWS_REGION=us-east-1

LOCAL_STORAGE_PATH=/app/storage

# ── Error Tracking (optional) ─────────────────────────────────────────────────
# SENTRY_DSN=https://changeme@sentry.io/0

# ── Celery / Workers ──────────────────────────────────────────────────────────
CELERY_CONCURRENCY=4
# Max LLM tasks per user at a time (prevents runaway cost)
MAX_LLM_TASKS_PER_USER=3

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Ingestion requests per user per hour
INGEST_RATE_LIMIT=20
# LLM generation requests per user per hour
LLM_RATE_LIMIT=50

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXTAUTH_URL=http://localhost:3000
# Same as SECRET_KEY — used by NextAuth
NEXTAUTH_SECRET=changeme_same_as_secret_key

# ── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
# development | staging | production
LOG_LEVEL=INFO
